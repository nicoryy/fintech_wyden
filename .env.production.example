# Wyden — variáveis de produção.
# Copie para `.env.production` e preencha com valores FORTES e ÚNICOS.
# O arquivo real (.env.production) está no .gitignore — NUNCA faça commit dele.
#
#   cp .env.production.example .env.production
#   # gere segredos: openssl rand -hex 32

# ── Banco de dados (PostgreSQL) ──────────────────────────────────────────────
DB_NAME=wyden_db
DB_USER=wyden
DB_PASS=TROQUE_por_uma_senha_forte

# Bootstrap do schema (não há migrations ainda):
#   • deixe `true` SOMENTE no primeiríssimo boot para o TypeORM criar as tabelas
#   • depois volte para `false` e recrie a api (ver DEPLOY.md)
DB_SYNCHRONIZE=false

# ── JWT (use strings longas e aleatórias: `openssl rand -hex 32`) ─────────────
JWT_SECRET=TROQUE_access_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=TROQUE_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d
